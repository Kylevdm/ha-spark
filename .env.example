# ha-spark configuration — copy to .env and fill in.
# All settings are read by ha_spark/config.py (pydantic-settings).

# --- Home Assistant ---
# ha-spark runs as an HA add-on by default: the REST/WebSocket URLs and the
# auth token are derived automatically from the Supervisor (SUPERVISOR_TOKEN),
# so HA_URL/HA_TOKEN can be left unset there.
#
# Standalone/dev escape hatch: set BOTH HA_URL and HA_TOKEN (a long-lived access
# token) to talk to an HA instance directly without the Supervisor.
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# --- Ollama (single remote tier) ---
# One remote Ollama instance, typically reached over Tailscale (a Tailnet IP
# such as http://100.x.y.z:11434). When it is unreachable, ha-spark falls back
# to a deterministic offline intent parser (no LLM).
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:14b
# Context window. Ollama defaults to 2048, which truncates agent prompts.
OLLAMA_NUM_CTX=32768

# --- Timeouts (seconds) ---
HA_TIMEOUT=10.0
OLLAMA_TIMEOUT=120.0
OLLAMA_HEALTH_TIMEOUT=2.0

# --- Storage ---
# SQLite memory store. Defaults under ./data (gitignored).
DB_PATH=data/ha_spark.db

# --- Logging ---
LOG_LEVEL=INFO

# --- Energy planner ---
# Proactivity gate for real control writes:
#   off      - compute the plan only
#   simulate - log what would be written, no real writes (default)
#   on       - real service calls to the inverter
PROACTIVE_MODE=simulate
# Safety margin applied to the forecast deficit before sizing the overnight
# charge (percent, e.g. 20 = charge 20% more than the forecast shortfall).
CHARGE_BUFFER_PCT=20.0
# Round-trip AC->DC->AC efficiency (5% loss each way): the planner buys
# required/efficiency AC kWh to deliver the required kWh back to the load.
CHARGE_EFFICIENCY=0.90
# Overnight sizing strategy:
#   deficit - charge only the forecast shortfall (cheapest with no export)
#   fill    - charge to TARGET_SOC_CAP every night (wins once
#             RATE_EXPORT_GBP_KWH > RATE_OFFPEAK_GBP_KWH: solar surplus then
#             exports instead of refilling the battery)
CHARGE_STRATEGY=deficit
# Solcast percentile to plan on: 50 = median, 10 = conservative, 90 = optimistic.
SOLAR_PERCENTILE=50

# --- Energy planner v2 ---
# Two-rate tariff (GBP/kWh): off-peak inside the charge window / dispatch slots.
RATE_OFFPEAK_GBP_KWH=0.069
RATE_PEAK_GBP_KWH=0.30
# Export/feed-in rate (GBP/kWh, e.g. 0.15 for Octopus Outgoing Fixed);
# 0 disables export revenue in projected costs.
RATE_EXPORT_GBP_KWH=0.0
# Slot-profile load model, built from hourly HA statistics of the house
# consumption sensor (true load — excludes battery charging and EV).
PROFILE_MIN_DAYS=7
PROFILE_HISTORY_DAYS=60
TIMEZONE=Europe/London
# Local time (HH:MM) at which `ha-spark run` computes/applies the daily plan.
PLAN_RUN_TIME=22:00
# Onboarding: `ha-spark backfill-load` rebuilds house-load history from this
# statistic (a true-load power/energy sensor; --from overrides, --list shows
# candidates) into ha_spark:house_load. Afterwards, point the forecast at it:
#   CONSUMPTION_ENERGY_ENTITY=ha_spark:house_load
BACKFILL_SOURCE_ENTITY=
# Octopus REST API credentials for `pull-consumption` (CSV import needs none).
# Grid-import history for cost backtesting — NOT used by the load model.
# API key from the Octopus dashboard; MPAN + meter serial from your bill.
OCTOPUS_API_KEY=
OCTOPUS_MPAN=
OCTOPUS_METER_SERIAL=
