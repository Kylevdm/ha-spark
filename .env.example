# ha-agent configuration — copy to .env and fill in.
# All settings are read by ha_agent/config.py (pydantic-settings).

# --- Home Assistant ---
# Standalone/dev: point at your HA instance and use a long-lived access token.
# When running as an HA add-on these are derived automatically from the
# Supervisor (see addon/ — Phase 6) and can be left unset.
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# --- Ollama (model tiers) ---
# Primary large model on the LAN GPU box (RTX 4070 Super 12GB).
OLLAMA_LAN_URL=http://gpu-box.local:11434
OLLAMA_LAN_MODEL=qwen3:14b
# Small fallback model on the HA device (x86 NUC, CPU-only).
OLLAMA_LOCAL_URL=http://127.0.0.1:11434
OLLAMA_LOCAL_MODEL=qwen3:4b
# Context window. Ollama defaults to 2048, which truncates agent prompts.
OLLAMA_NUM_CTX=32768

# --- Timeouts (seconds) ---
HA_TIMEOUT=10.0
OLLAMA_TIMEOUT=120.0
OLLAMA_HEALTH_TIMEOUT=2.0

# --- Storage ---
# SQLite memory store. Defaults under ./data (gitignored).
DB_PATH=data/ha_agent.db

# --- Logging ---
LOG_LEVEL=INFO
